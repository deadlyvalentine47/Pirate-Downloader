{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": [
            "-y",
            "-user_agent",
            {"validator": ".*"},
            "-referer",
            {"validator": ".*"},
            "-protocol_whitelist",
            "file,http,https,tcp,tls,crypto,data",
            "-headers",
            {"validator": ".*"},
            "-f",
            "hls",
            "-allowed_extensions",
            "all",
            "-i",
            {"validator": ".*"},
            "-c",
            "copy",
            {"validator": ".*"}
          ],
          "sidecar": "ffmpeg"
        }
      ]
    }
  ]
}